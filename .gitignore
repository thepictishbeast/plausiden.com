/target
/dist
**/*.rs.bk
*.pdb

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.swp

# Local env (never committed — secrets live in systemd EnvironmentFile on the host)
.env
.env.*

# Backup artifacts
*.bak
*.tar.gz

# Insta snapshot pending-review files; the accepted .snap files ARE
# committed (they are the test oracle). The .new / .pending files are
# local-only until `cargo insta review` accepts them.
**/*.snap.new
**/*.pending-snap
